ph_box1_size 	         = 0.1,  0.05,  0.1
ph_crash_speed_min       = 16
ph_crash_speed_max       = 30
ph_mass 		         = 1


;------------------------------------------------------------------------------
;----------------------------- Entity Conditions ------------------------------
;------------------------------------------------------------------------------
satiety_v				= 0.0				;скорость уменьшения сытости со временем [0...1]
